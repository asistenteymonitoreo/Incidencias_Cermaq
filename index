<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi App Firebase Sencilla</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>¡Envía un Mensaje a Firebase!</h1>

        <div class="form-section">
            <input type="text" id="nombreInput" placeholder="Tu Nombre">
            <textarea id="mensajeInput" placeholder="Tu Mensaje"></textarea>
            <button id="enviarBtn">Enviar Mensaje</button>
        </div>

        <hr>

        <h2>Mensajes Recibidos</h2>
        <div id="mensajesLista">
            <p class="loading-message">Cargando mensajes...</p>
        </div>
    </div>

    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-database-compat.js"></script>

    <script src="script.js"></script>
</body>
</html>